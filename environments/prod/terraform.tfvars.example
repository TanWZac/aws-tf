aws_region                = "us-east-1"
project_name              = "platform-ai"
environment               = "prod"
vpc_cidr                  = "10.40.0.0/16"
availability_zones        = ["us-east-1a", "us-east-1b"]
nat_gateway_mode          = "per_az"
enable_vpc_endpoints      = true
create_sagemaker_notebook = true
sagemaker_instance_type   = "ml.m5.large"
enable_app_service        = true
app_container_image       = "public.ecr.aws/nginx/nginx:stable"
app_container_port        = 80
app_task_cpu              = 2048
app_task_memory           = 4096
app_desired_count         = 4
app_min_capacity          = 4
app_max_capacity          = 30
app_health_check_path     = "/"
enable_alb_https          = true
alb_certificate_arn       = "arn:aws:acm:us-east-1:ACCOUNT_ID:certificate/CERT_ID" # TODO: replace with a real ACM certificate ARN
enable_waf                = true
waf_rate_limit            = 3000
enable_alb_deletion_protection = true
enable_alb_access_logs    = true
enable_waf_logging        = true
create_edge_logs_bucket   = true
edge_logs_bucket_name     = null
edge_logs_prefix          = "edge"
edge_logs_retention_days  = 365
enable_edge_logs_kms_encryption = true
create_edge_logs_kms_key  = false
edge_logs_kms_key_arn     = "arn:aws:kms:us-east-1:123456789012:key/replace-me"
enable_deployment_circuit_breaker = true
deployment_rollback_on_failure    = true
enable_request_count_autoscaling  = true
request_count_target              = 800
request_scale_in_cooldown         = 180
request_scale_out_cooldown        = 45
additional_tags = {
  Owner      = "platform-team"
  CostCenter = "engineering"
  DataClass  = "confidential"
}
