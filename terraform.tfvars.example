aws_region                = "us-east-1"
aws_profile               = null
allowed_account_ids       = []
project_name              = "platform-ai"
environment               = "dev"
vpc_cidr                  = "10.20.0.0/16"
availability_zones        = ["us-east-1a", "us-east-1b"]
nat_gateway_mode          = "single"
enable_vpc_endpoints      = true
create_sagemaker_notebook = true
sagemaker_instance_type   = "ml.t3.medium"
enable_app_service        = true
app_container_image       = "public.ecr.aws/nginx/nginx:stable"
app_container_port        = 80
app_task_cpu              = 512
app_task_memory           = 1024
app_desired_count         = 2
app_min_capacity          = 2
app_max_capacity          = 10
app_health_check_path     = "/"
enable_alb_https          = false
alb_certificate_arn       = null
alb_ssl_policy            = "ELBSecurityPolicy-TLS13-1-2-2021-06"
enable_waf                = false
waf_rate_limit            = 2000
enable_alb_deletion_protection = true
enable_alb_access_logs    = true
enable_waf_logging        = true
create_edge_logs_bucket   = true
edge_logs_bucket_name     = null
edge_logs_prefix          = "edge"
enable_deployment_circuit_breaker = true
deployment_rollback_on_failure    = true
enable_request_count_autoscaling  = true
request_count_target              = 800
request_scale_in_cooldown         = 180
request_scale_out_cooldown        = 60
additional_tags = {
  Owner      = "platform-team"
  CostCenter = "engineering"
}
